<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>合同条款智能审计</title>
<style>
  :root {
    --bg: oklch(97% 0.003 80);
    --surface: oklch(100% 0 0);
    --surface-2: oklch(98% 0.003 80);
    --surface-3: oklch(95% 0.003 80);
    --border: oklch(91% 0 0);
    --border-soft: oklch(94% 0 0);
    --text: oklch(15% 0 0);
    --text-2: oklch(40% 0 0);
    --text-3: oklch(60% 0 0);
    --accent: oklch(55% 0.18 255);
    --accent-hover: oklch(48% 0.18 255);
    --accent-soft: oklch(55% 0.18 255 / 0.10);
    --accent-veil: oklch(55% 0.18 255 / 0.18);
    --high: oklch(50% 0.18 25);
    --high-soft: oklch(96% 0.03 25);
    --high-mark: oklch(85% 0.08 25);
    --mid: oklch(55% 0.13 70);
    --mid-soft: oklch(97% 0.04 80);
    --mid-mark: oklch(88% 0.10 75);
    --low: oklch(48% 0.13 150);
    --low-soft: oklch(96% 0.03 150);
    --review: oklch(45% 0.18 290);
    --review-soft: oklch(96% 0.04 290);
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
    --t-fast: 150ms var(--ease);
    --t: 220ms var(--ease);
    --shadow-lift: 0 10px 32px -12px oklch(15% 0 0 / 0.12), 0 2px 6px oklch(15% 0 0 / 0.04);
    --shadow-modal: 0 24px 64px -16px oklch(15% 0 0 / 0.22);
  }

  *, *::before, *::after { box-sizing: border-box; }
  html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Helvetica Neue", "Microsoft YaHei", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    font-size: 15px;
    min-height: 100vh;
  }
  h1, h2, h3, h4 {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
    margin: 0;
    letter-spacing: -0.015em;
  }
  ::selection { background: var(--accent-veil); }
  button { font: inherit; }

  /* ============ Top Nav ============ */
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: oklch(97% 0.003 80 / 0.82);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--border-soft);
  }
  .nav-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .brand {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
    display: flex; align-items: center; gap: 10px;
  }
  .brand-mark {
    width: 24px; height: 24px;
    border-radius: 7px;
    background: var(--text);
    display: grid; place-items: center;
    color: white; font-size: 13px; font-weight: 600;
    letter-spacing: 0;
  }
  .brand-tag {
    font-size: 11px;
    color: var(--text-3);
    margin-left: 4px;
    font-weight: 400;
    padding: 2px 8px;
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  .nav-back {
    font-size: 13px;
    color: var(--text-2);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 6px 12px;
    border-radius: 999px;
    display: flex; align-items: center; gap: 4px;
    transition: background var(--t-fast), color var(--t-fast);
  }
  .nav-back:hover { background: var(--surface-3); color: var(--text); }
  .nav-actions { margin-left: auto; display: flex; gap: 6px; align-items: center; }
  .nav-btn {
    font-size: 13px;
    padding: 7px 14px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid transparent;
    color: var(--text-2);
    cursor: pointer;
    transition: background var(--t-fast), color var(--t-fast);
  }
  .nav-btn:hover { background: var(--surface-3); color: var(--text); }

  .container { max-width: 1320px; margin: 0 auto; padding: 0 32px; }

  /* ============ View System ============ */
  .view { display: none; }
  .view.active { display: block; animation: rise 320ms var(--ease); }
  @keyframes rise {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ============ Landing View ============ */
  .landing {
    min-height: calc(100vh - 60px);
    display: grid;
    place-items: center;
    padding: 48px 24px 96px;
  }
  .landing-inner {
    width: 100%;
    max-width: 640px;
    text-align: center;
  }
  .landing h1 {
    font-size: clamp(34px, 5vw, 48px);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
  }
  .landing-sub {
    font-size: 17px;
    color: var(--text-2);
    line-height: 1.6;
    margin-bottom: 48px;
    max-width: 520px;
    margin-left: auto; margin-right: auto;
  }

  .upload-card {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 20px;
    padding: 8px;
    box-shadow: var(--shadow-lift);
  }
  .upload-zone {
    position: relative;
    border: 1.5px dashed var(--border);
    border-radius: 14px;
    padding: 56px 24px;
    text-align: center;
    cursor: pointer;
    background: var(--surface-2);
    transition: border-color var(--t-fast), background var(--t-fast);
  }
  .upload-zone:hover, .upload-zone.drag {
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .upload-zone input {
    position: absolute; inset: 0; opacity: 0; cursor: pointer;
  }
  .upload-icon {
    width: 56px; height: 56px;
    margin: 0 auto 16px;
    border-radius: 16px;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    display: grid; place-items: center;
    color: var(--text-2);
  }
  .upload-icon svg { width: 26px; height: 26px; }
  .upload-title { font-size: 16px; font-weight: 500; color: var(--text); }
  .upload-hint { font-size: 13px; color: var(--text-3); margin-top: 6px; }

  .file-pill {
    margin: 16px 8px 8px;
    padding: 12px 16px;
    background: var(--surface-2);
    border: 1px solid var(--border-soft);
    border-radius: 12px;
    display: flex; align-items: center; gap: 12px;
  }
  .file-pill-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent);
    display: grid; place-items: center;
    flex-shrink: 0;
  }
  .file-pill-icon svg { width: 18px; height: 18px; }
  .file-pill-name {
    flex: 1; min-width: 0;
    font-size: 14px; font-weight: 500;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .file-pill-size { font-size: 12px; color: var(--text-3); margin-right: 8px; }
  .file-pill-remove {
    width: 28px; height: 28px;
    border: none; background: transparent; cursor: pointer;
    border-radius: 50%;
    color: var(--text-3);
    display: grid; place-items: center;
    transition: background var(--t-fast), color var(--t-fast);
  }
  .file-pill-remove:hover { background: var(--surface-3); color: var(--text); }
  .file-pill-remove svg { width: 14px; height: 14px; }

  .start-area {
    margin-top: 24px;
    display: flex; justify-content: center;
  }
  .btn {
    display: inline-flex;
    align-items: center; justify-content: center;
    gap: 8px;
    padding: 12px 22px;
    font-size: 14px;
    font-weight: 500;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    transition: background var(--t-fast), color var(--t-fast), opacity var(--t-fast);
  }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-primary {
    background: var(--accent); color: white;
    padding: 14px 28px; font-size: 15px;
    min-width: 200px;
  }
  .btn-primary:hover:not(:disabled) { background: var(--accent-hover); }
  .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { background: var(--surface-3); }
  .btn-accent {
    background: var(--accent-soft); color: var(--accent);
  }
  .btn-accent:hover { background: var(--accent-veil); }
  .btn-text {
    background: transparent; color: var(--accent);
    padding: 8px 12px;
  }
  .btn-text:hover { background: var(--accent-soft); }

  .landing-foot {
    margin-top: 36px;
    font-size: 12px;
    color: var(--text-3);
    display: flex; justify-content: center; gap: 18px;
  }
  .landing-foot span { display: inline-flex; align-items: center; gap: 6px; }
  .landing-foot span::before {
    content: "";
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--text-3);
  }
  .landing-foot span:first-child::before { display: none; }

  /* ============ Review View ============ */
  .review { padding: 32px 0 96px; }

  /* Doc header */
  .doc-header {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding: 8px 0 24px;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--border-soft);
  }
  .doc-meta { flex: 1; min-width: 0; }
  .doc-title {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 6px;
    overflow: hidden; text-overflow: ellipsis;
  }
  .doc-sub {
    font-size: 13px;
    color: var(--text-3);
    display: flex; gap: 14px; flex-wrap: wrap;
  }
  .doc-sub span { display: inline-flex; align-items: center; gap: 5px; }
  .doc-sub b {
    color: var(--text); font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .doc-actions {
    display: flex;
    align-items: center; gap: 10px;
    flex-wrap: wrap; flex-shrink: 0;
  }
  .seg {
    display: inline-flex;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 3px;
  }
  .seg button {
    border: none; background: transparent;
    padding: 7px 14px;
    font-size: 13px; font-weight: 500;
    color: var(--text-2);
    border-radius: 999px;
    cursor: pointer;
    transition: background var(--t-fast), color var(--t-fast);
  }
  .seg button:hover { background: var(--surface-3); color: var(--text); }
  .seg-label {
    font-size: 12px;
    color: var(--text-3);
    margin-right: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Summary banner */
  .summary-banner {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    padding: 24px 28px;
    margin-bottom: 28px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: center;
  }
  @media (max-width: 720px) {
    .summary-banner { grid-template-columns: 1fr; }
  }
  .summary-headline {
    display: flex;
    align-items: center; gap: 14px;
    flex-wrap: wrap;
  }
  .summary-level {
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.022em;
    line-height: 1.05;
  }
  .summary-level.high { color: var(--high); }
  .summary-level.mid { color: var(--mid); }
  .summary-level.low { color: var(--low); }
  .summary-stats {
    display: flex; gap: 28px;
    align-items: center;
    flex-wrap: wrap;
  }
  .summary-stat-v {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .summary-stat-k {
    font-size: 11px;
    color: var(--text-3);
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  /* Progress */
  .progress-bar {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 12px;
    padding: 14px 20px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .progress-bar.done { display: none; }
  .progress-spinner {
    width: 18px; height: 18px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 700ms linear infinite;
    flex-shrink: 0;
  }
  .progress-text { flex: 1; font-size: 13px; color: var(--text-2); }
  .progress-text b { color: var(--text); font-weight: 500; font-variant-numeric: tabular-nums; }
  .progress-track {
    height: 4px;
    background: var(--surface-3);
    border-radius: 2px;
    overflow: hidden;
    flex: 1.4;
  }
  .progress-fill {
    height: 100%; width: 0;
    background: var(--accent);
    transition: width 280ms var(--ease);
    border-radius: 2px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ============ Doc + Comments grid ============ */
  .doc-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 28px;
    align-items: start;
  }
  @media (max-width: 980px) {
    .doc-grid { grid-template-columns: 1fr; }
  }

  .doc-paper {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    padding: 40px 48px;
    min-height: 60vh;
  }
  @media (max-width: 720px) {
    .doc-paper { padding: 28px 24px; }
  }

  .clause-list {
    list-style: none;
    padding: 0; margin: 0;
    counter-reset: clause;
  }
  .clause {
    position: relative;
    padding: 14px 16px 14px 44px;
    margin: 6px -16px;
    border-radius: 10px;
    line-height: 1.85;
    font-size: 15.5px;
    color: var(--text);
    transition: background var(--t-fast);
    cursor: pointer;
    counter-increment: clause;
  }
  .clause::before {
    content: counter(clause);
    position: absolute;
    left: 14px; top: 19px;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--surface-3);
    color: var(--text-3);
    font-size: 11px;
    font-weight: 500;
    display: grid; place-items: center;
    font-variant-numeric: tabular-nums;
    transition: background var(--t-fast), color var(--t-fast);
  }
  .clause:hover { background: var(--surface-2); }
  .clause.active { background: var(--accent-soft); }
  .clause.active::before { background: var(--accent); color: white; }

  .clause.high {
    background: var(--high-soft);
    text-decoration: underline wavy var(--high);
    text-underline-offset: 5px;
    text-decoration-thickness: 1.5px;
  }
  .clause.high::before { background: var(--high); color: white; }
  .clause.high.active { background: oklch(94% 0.05 25); }

  .clause.mid {
    background: var(--mid-soft);
    text-decoration: underline wavy var(--mid);
    text-underline-offset: 5px;
    text-decoration-thickness: 1.5px;
  }
  .clause.mid::before { background: var(--mid); color: white; }
  .clause.mid.active { background: oklch(94% 0.06 75); }

  .clause.low::before { background: var(--low); color: white; }
  .clause.pending { color: var(--text-3); }
  .clause.pending::before {
    background: var(--surface-3);
    color: transparent;
    border: 1.5px solid var(--border);
    animation: pulse 1.4s var(--ease) infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  .clause-indicator {
    position: absolute;
    right: 12px; top: 18px;
    width: 8px; height: 8px;
    border-radius: 50%;
  }
  .clause.high .clause-indicator { background: var(--high); }
  .clause.mid .clause-indicator { background: var(--mid); }
  .clause.low .clause-indicator { background: var(--low); }

  /* ============ Comments column ============ */
  .comments {
    position: relative;
    align-self: stretch;
  }
  .comments-inner {
    position: sticky; top: 80px;
    display: flex; flex-direction: column;
    gap: 12px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding-right: 4px;
    padding-bottom: 24px;
  }
  .comments-inner::-webkit-scrollbar { width: 6px; }
  .comments-inner::-webkit-scrollbar-thumb {
    background: var(--border); border-radius: 3px;
  }
  .comments-empty {
    padding: 40px 20px;
    text-align: center;
    font-size: 13px;
    color: var(--text-3);
  }

  .comment {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 12px;
    padding: 16px;
    cursor: pointer;
    transition: border-color var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast);
  }
  .comment:hover {
    border-color: var(--border);
    transform: translateY(-1px);
    box-shadow: var(--shadow-lift);
  }
  .comment.active {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .comment-head {
    display: flex;
    align-items: center; gap: 8px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .comment-anchor {
    font-size: 11px;
    color: var(--text-3);
    font-weight: 500;
    margin-left: auto;
    font-variant-numeric: tabular-nums;
  }
  .comment-body {
    font-size: 13px;
    line-height: 1.65;
    color: var(--text-2);
  }
  .comment-body strong {
    color: var(--text);
    font-size: 12px;
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
    margin-top: 8px;
  }
  .comment-body strong:first-child { margin-top: 0; }
  .comment-body p {
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .comment-foot {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border-soft);
    display: flex;
    align-items: center; gap: 10px;
  }
  .comment-foot .mono {
    background: var(--surface-2);
    border: 1px solid var(--border-soft);
    padding: 3px 8px;
    border-radius: 6px;
    font-size: 11px;
  }
  .comment-foot .grow { flex: 1; }
  .comment-adopt {
    font-size: 12px;
    padding: 5px 11px;
    background: transparent;
    color: var(--accent);
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
    transition: background var(--t-fast);
  }
  .comment-adopt:hover { background: var(--accent-soft); }

  /* Pass card (low risk shortcut) */
  .comment-pass {
    background: transparent;
    border: 1px dashed var(--border-soft);
    border-radius: 10px;
    padding: 10px 14px;
    display: flex;
    align-items: center; gap: 8px;
    color: var(--low);
    font-size: 12px;
    cursor: pointer;
  }
  .comment-pass:hover { background: var(--low-soft); border-style: solid; }
  .comment-pass svg { width: 14px; height: 14px; }

  /* ============ Chips ============ */
  .chip {
    display: inline-flex;
    align-items: center; gap: 4px;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 11.5px;
    font-weight: 500;
    background: var(--surface-2);
    color: var(--text-2);
    border: 1px solid var(--border-soft);
    line-height: 1.4;
  }
  .chip.high { background: var(--high-soft); color: var(--high); border-color: transparent; }
  .chip.mid { background: var(--mid-soft); color: var(--mid); border-color: transparent; }
  .chip.low { background: var(--low-soft); color: var(--low); border-color: transparent; }
  .chip.review { background: var(--review-soft); color: var(--review); border-color: transparent; }
  .chip-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: currentColor;
  }
  .mono {
    font-family: "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
    font-size: 12px;
    color: var(--text-2);
    font-variant-numeric: tabular-nums;
  }

  /* ============ Details (extra info) ============ */
  .extra {
    margin-top: 36px;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 16px;
    overflow: hidden;
  }
  .extra-h {
    padding: 18px 24px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    border-bottom: 1px solid var(--border-soft);
  }
  details.extra-row { border-bottom: 1px solid var(--border-soft); }
  details.extra-row:last-of-type { border-bottom: none; }
  details.extra-row > summary {
    list-style: none;
    cursor: pointer;
    padding: 16px 24px;
    display: flex; align-items: center; gap: 10px;
    font-size: 14px; font-weight: 500;
    color: var(--text);
    user-select: none;
    transition: background var(--t-fast);
  }
  details.extra-row > summary:hover { background: var(--surface-2); }
  details.extra-row > summary::-webkit-details-marker { display: none; }
  details.extra-row > summary::after {
    content: "";
    width: 7px; height: 7px;
    margin-left: auto;
    border-right: 1.5px solid var(--text-3);
    border-bottom: 1.5px solid var(--text-3);
    transform: rotate(45deg);
    transition: transform var(--t);
  }
  details.extra-row[open] > summary::after { transform: rotate(-135deg); }
  .extra-body {
    padding: 4px 24px 20px;
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Timing grid */
  .timing-grid {
    padding: 4px 24px 20px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 10px;
  }
  .timing-cell {
    background: var(--surface-2);
    border: 1px solid var(--border-soft);
    border-radius: 10px;
    padding: 12px;
    text-align: center;
  }
  .timing-v {
    font-size: 16px;
    font-family: "SF Mono", Menlo, Consolas, monospace;
    color: var(--accent);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }
  .timing-k {
    font-size: 11px;
    color: var(--text-3);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ============ Drawer / Modal / Toast ============ */
  .mask {
    position: fixed; inset: 0;
    background: oklch(15% 0 0 / 0.4);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    opacity: 0; visibility: hidden;
    transition: opacity var(--t), visibility var(--t);
    z-index: 90;
  }
  .mask.show { opacity: 1; visibility: visible; }
  .drawer {
    position: fixed; top: 0; right: 0;
    width: min(560px, 92vw); height: 100%;
    background: var(--bg);
    box-shadow: var(--shadow-modal);
    transform: translateX(100%);
    transition: transform 300ms var(--ease);
    z-index: 91;
    display: flex; flex-direction: column;
  }
  .drawer.show { transform: translateX(0); }
  .drawer-h {
    padding: 20px 28px;
    border-bottom: 1px solid var(--border-soft);
    display: flex; align-items: center; gap: 8px;
  }
  .drawer-h h3 { font-size: 16px; font-weight: 600; }
  .drawer-count { font-size: 12px; color: var(--text-3); }
  .drawer-close {
    margin-left: auto;
    width: 32px; height: 32px;
    border: none; background: transparent; cursor: pointer;
    border-radius: 50%;
    display: grid; place-items: center;
    color: var(--text-3);
    transition: background var(--t-fast), color var(--t-fast);
    font-size: 22px; line-height: 1;
  }
  .drawer-close:hover { background: var(--surface-3); color: var(--text); }
  .drawer-b {
    flex: 1; overflow-y: auto; padding: 20px 28px;
  }
  .hist-item {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 12px;
  }
  .hi-meta { display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; }
  .hi-c {
    font-size: 13px; line-height: 1.65; color: var(--text);
    margin-bottom: 10px; white-space: pre-wrap;
  }
  .hi-s {
    font-size: 13px; color: var(--text-2);
    padding: 10px 12px;
    background: var(--surface-2);
    border-radius: 8px;
    line-height: 1.6;
  }

  .modal {
    position: fixed; inset: 0;
    display: none;
    place-items: center;
    z-index: 100;
    padding: 24px;
  }
  .modal.show { display: grid; }
  .modal-card {
    background: var(--surface);
    border-radius: 16px;
    padding: 28px;
    box-shadow: var(--shadow-modal);
    width: 100%; max-width: 440px;
    border: 1px solid var(--border-soft);
  }
  .modal-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 16px; }
  .health-list { display: grid; gap: 8px; }
  .health-row {
    display: flex;
    align-items: center; justify-content: space-between;
    padding: 12px 14px;
    background: var(--surface-2);
    border-radius: 10px;
    font-size: 14px;
  }
  .h-status {
    font-size: 12px; font-weight: 500;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .h-ok { color: var(--low); }
  .h-fail { color: var(--high); }
  .h-dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; }

  .toast {
    position: fixed;
    bottom: 32px; left: 50%;
    transform: translateX(-50%) translateY(16px);
    background: oklch(15% 0 0);
    color: white;
    padding: 11px 18px;
    border-radius: 999px;
    font-size: 13px; font-weight: 500;
    opacity: 0;
    transition: opacity var(--t), transform var(--t);
    pointer-events: none;
    z-index: 95;
    box-shadow: var(--shadow-modal);
    max-width: 90vw; text-align: center;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .toast.error { background: var(--high); }
  .toast.success { background: var(--low); }

  /* ============ Document body (inline annotation) ============ */
  .doc-body {
    font-size: 15.5px;
    line-height: 1.85;
    color: var(--text);
    white-space: pre-wrap;
    word-break: break-word;
  }
  .doc-normal { }
  .clause-risk {
    display: inline;
    padding: 2px 0;
    border-radius: 4px;
    cursor: pointer;
    transition: background var(--t-fast);
  }
  .clause-risk.high {
    background: var(--high-soft);
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    border-left: 3px solid var(--high);
    padding-left: 6px;
    margin-left: -4px;
  }
  .clause-risk.mid {
    background: var(--mid-soft);
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    border-left: 3px solid var(--mid);
    padding-left: 6px;
    margin-left: -4px;
  }
  .clause-risk.replaced {
    background: var(--low-soft);
    border-left-color: var(--low);
  }
  .clause-risk:hover { filter: brightness(0.97); }
  .clause-risk.active {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Revision card in sidebar */
  .revision-box {
    margin-top: 12px;
    padding: 12px;
    background: var(--surface-2);
    border: 1px solid var(--border-soft);
    border-radius: 10px;
    font-size: 13px;
    line-height: 1.65;
    color: var(--text);
    white-space: pre-wrap;
  }
  .revision-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }
  .revision-actions {
    display: flex;
    gap: 8px;
    margin-top: 10px;
  }
  .revision-actions .btn {
    padding: 7px 14px;
    font-size: 12px;
    border-radius: 999px;
  }

  /* Empty state */
  .comments-empty {
    padding: 40px 20px;
    text-align: center;
    font-size: 13px;
    color: var(--text-3);
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { transition: none !important; animation: none !important; }
  }
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <div class="brand">
      <span class="brand-mark">合</span>
      合同条款智能审计<span class="brand-tag">v2.0</span>
    </div>
    <button class="nav-back" id="btn-back" style="display:none;">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      重新上传
    </button>
    <div class="nav-actions">
      <button class="nav-btn" id="btn-health">运行状态</button>
      <button class="nav-btn" id="btn-history">采纳库</button>
    </div>
  </div>
</nav>

<!-- ============ View 1: Landing ============ -->
<section class="view active" id="view-landing">
  <div class="landing">
    <div class="landing-inner">
      <h1>把合同里的雷,圈出来。</h1>
      <p class="landing-sub">上传一份合同,LLM 与规则引擎逐条标注风险类型、引用法规、给出修改建议。</p>

      <div class="upload-card">
        <label class="upload-zone" id="upload-zone">
          <input type="file" id="file-input" accept=".txt,.pdf,.docx">
          <div class="upload-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
          </div>
          <div class="upload-title">拖入或选择合同文件</div>
          <div class="upload-hint">.txt · .docx · .pdf · 单文件 ≤ 5 MB</div>
        </label>

        <div class="file-pill" id="file-pill" style="display:none;">
          <div class="file-pill-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
          <div class="file-pill-name" id="file-pill-name"></div>
          <div class="file-pill-size mono" id="file-pill-size"></div>
          <button class="file-pill-remove" id="file-pill-remove" aria-label="移除文件">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>

      <div class="start-area">
        <button class="btn btn-primary" id="btn-start" disabled>开始审计</button>
      </div>

      <div class="landing-foot">
        <span>双通道融合</span>
        <span>GLM-4.7-Flash</span>
        <span>P × L × D 半定量评估</span>
      </div>
    </div>
  </div>
</section>

<!-- ============ View 2: Review ============ -->
<section class="view" id="view-review">
  <div class="container review">

    <div class="doc-header">
      <div class="doc-meta">
        <div class="doc-title" id="rv-title">合同审计报告</div>
        <div class="doc-sub" id="rv-sub"></div>
      </div>
      <div class="doc-actions">
        <button class="btn btn-primary" id="btn-export-revised">导出修订版</button>
      </div>
    </div>

    <div class="summary-banner" id="rv-banner">
      <div class="summary-headline">
        <div class="summary-level" id="rv-level">审计中</div>
        <div class="summary-stats" id="rv-stats"></div>
      </div>
    </div>

    <div class="progress-bar" id="rv-progress">
      <div class="progress-spinner"></div>
      <div class="progress-text" id="rv-progress-text">正在分析合同结构…</div>
      <div class="progress-track"><div class="progress-fill" id="rv-progress-fill"></div></div>
    </div>

    <div class="doc-grid">
      <div class="doc-paper">
        <div class="doc-body" id="doc-body">解析中…</div>
      </div>
      <div class="comments">
        <div class="comments-inner" id="comments-list">
          <div class="comments-empty">审计完成后，问题条款会出现在这里。</div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ============ Drawer ============ -->
<div class="mask" id="mask"></div>
<aside class="drawer" id="drawer" aria-hidden="true">
  <div class="drawer-h">
    <h3>历史采纳库</h3>
    <span class="drawer-count" id="drawer-count"></span>
    <button class="drawer-close" id="drawer-close" aria-label="关闭">×</button>
  </div>
  <div class="drawer-b" id="drawer-body"></div>
</aside>

<!-- ============ Health Modal ============ -->
<div class="mask" id="health-mask"></div>
<div class="modal" id="health-modal">
  <div class="modal-card">
    <h3>运行状态</h3>
    <div class="health-list" id="health-list">
      <div style="color: var(--text-3); text-align:center; padding: 16px;">检测中…</div>
    </div>
    <div style="margin-top: 20px; text-align: right;">
      <button class="btn btn-ghost" id="health-close">关闭</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  const API = "http://127.0.0.1:8000";

  const state = {
    file: null,
    filename: "",
    content: "",
    clauses: [],          // [{id, text, status, audit}]
    initialAudit: null,   // /upload 全文的初始审计
    timing: {},
    aborter: null,
  };

  const $ = id => document.getElementById(id);
  const esc = s => String(s ?? "").replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
  const levelKey = level => {
    if (!level) return "mid";
    const s = String(level);
    if (s.includes("高")) return "high";
    if (s.includes("低")) return "low";
    return "mid";
  };
  function toast(msg, type = "") {
    const el = $("toast");
    el.textContent = msg;
    el.className = "toast show " + type;
    clearTimeout(toast._t);
    toast._t = setTimeout(() => el.className = "toast " + type, 2400);
  }
  function showView(name) {
    document.querySelectorAll(".view").forEach(v => v.classList.remove("active"));
    $("view-" + name).classList.add("active");
    $("btn-back").style.display = name === "review" ? "inline-flex" : "none";
    window.scrollTo({top: 0, behavior: "instant"});
  }
  function formatBytes(n) {
    if (n < 1024) return n + " B";
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + " KB";
    return (n / (1024 * 1024)).toFixed(2) + " MB";
  }

  // ====== Landing: file selection ======
  function setFile(f) {
    if (!f) {
      state.file = null;
      $("file-pill").style.display = "none";
      $("upload-zone").style.display = "block";
      $("btn-start").disabled = true;
      return;
    }
    if (f.size > 5 * 1024 * 1024) { toast("文件超过 5 MB", "error"); return; }
    state.file = f;
    $("file-pill-name").textContent = f.name;
    $("file-pill-size").textContent = formatBytes(f.size);
    $("file-pill").style.display = "flex";
    $("upload-zone").style.display = "none";
    $("btn-start").disabled = false;
  }
  $("file-input").addEventListener("change", e => {
    const f = e.target.files[0];
    if (f) setFile(f);
    e.target.value = "";
  });
  $("file-pill-remove").addEventListener("click", () => setFile(null));

  const dropZone = $("upload-zone");
  ["dragenter", "dragover", "dragleave", "drop"].forEach(ev =>
    dropZone.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); }));
  ["dragenter", "dragover"].forEach(ev =>
    dropZone.addEventListener(ev, () => dropZone.classList.add("drag")));
  ["dragleave", "drop"].forEach(ev =>
    dropZone.addEventListener(ev, () => dropZone.classList.remove("drag")));
  dropZone.addEventListener("drop", e => {
    const f = e.dataTransfer?.files?.[0];
    if (f) setFile(f);
  });

  // ====== Start audit: upload → create document job → poll ======
  $("btn-start").addEventListener("click", async () => {
    if (!state.file) return;
    $("btn-start").disabled = true;
    $("btn-start").textContent = "解析中…";
    try {
      const fd = new FormData();
      fd.append("file", state.file);
      const res = await fetch(`${API}/upload`, {method: "POST", body: fd});
      if (!res.ok) throw new Error((await res.json().catch(() => ({}))).detail || res.statusText);
      const data = await res.json();
      state.filename = data.filename || state.file.name;
      state.content = data.content || "";
      state.initialAudit = data;
      state.timing = data.timing || {};
      enterReview();
      // 后台开始逐段审计
      startBatchAudit();
      if (data.parse_warning) toast("解析提示:" + data.parse_warning, "error");
    } catch (e) {
      toast("处理失败:" + e.message, "error");
    } finally {
      $("btn-start").disabled = false;
      $("btn-start").textContent = "开始审计";
    }
  });

  $("btn-back").addEventListener("click", () => {
    if (state.aborter) state.aborter.abort();
    showView("landing");
  });

  // ====== Split content into clauses ======
  function splitClauses(text) {
    const lines = text.split(/\n+/).map(s => s.trim()).filter(Boolean);
    const out = [];
    lines.forEach(line => {
      // 按中文句号/分号继续切分长行
      const parts = line.split(/(?<=[。;；])/).map(s => s.trim()).filter(Boolean);
      parts.forEach(p => { if (p.length >= 8) out.push(p); });
    });
    return out.slice(0, 24); // 安全上限
  }

  // ====== Enter Review View ======
  function enterReview() {
    showView("review");

    // 标题区
    $("rv-title").textContent = state.filename;
    $("rv-sub").innerHTML = `
      <span>解析 <b>${formatBytes(state.file.size)}</b></span>
      <span>解析耗时 <b>${(state.timing.parse || 0).toFixed(2)} s</b></span>
      <span id="rv-sub-progress">逐段审计待启动</span>
    `;

    // 顶部摘要带 = 整文初始审计
    paintBanner(state.initialAudit);

    // 拆分条款,渲染列表
    state.clauses = splitClauses(state.content).map((text, i) => ({
      id: "c" + i,
      text,
      status: "pending",
      audit: null,
    }));
    renderClauses();
    renderComments();

    // 法规、历史、耗时
    $("rv-law").textContent = state.initialAudit.law_context || "无相关法规命中。";
    $("rv-hist").textContent = state.initialAudit.historical_context || "采纳库中暂无相似条款记录。";
    renderTiming();
  }

  function paintBanner(r) {
    const lk = levelKey(r?.level);
    $("rv-level").textContent = r?.level || "—";
    $("rv-level").className = "summary-level " + lk;
    $("rv-type").innerHTML = `<span class="chip-dot"></span>${esc(r?.risk_type || "其他")}`;
    $("rv-type").className = "chip " + lk;
    $("rv-conf").textContent = `置信度 ${(r?.confidence ?? 0).toFixed(2)}`;
    const rs = r?.risk_score || {};
    $("rv-stats").innerHTML = `
      <div><div class="summary-stat-v">${rs.p ?? "·"}</div><div class="summary-stat-k">P · 概率</div></div>
      <div><div class="summary-stat-v">${rs.l ?? "·"}</div><div class="summary-stat-k">L · 损失</div></div>
      <div><div class="summary-stat-v">${rs.d ?? "·"}</div><div class="summary-stat-k">D · 可检测</div></div>
      <div><div class="summary-stat-v">${r?.rpn ?? "·"}</div><div class="summary-stat-k">RPN</div></div>
    `;
  }

  function renderClauses() {
    const list = $("clause-list");
    list.innerHTML = state.clauses.map(c => `
      <li class="clause ${c.status === "pending" ? "pending" : (c.audit ? levelKey(c.audit.level) : "")}"
          data-id="${c.id}">
        ${esc(c.text)}
        ${c.audit ? '<span class="clause-indicator"></span>' : ""}
      </li>
    `).join("");
    list.querySelectorAll(".clause").forEach(el => {
      el.addEventListener("click", () => focusClause(el.dataset.id));
    });
  }

  function renderComments() {
    const audited = state.clauses.filter(c => c.audit);
    const list = $("comments-list");
    if (audited.length === 0 && !state.initialAudit) {
      list.innerHTML = `<div class="comments-empty">完成一段审计后,这里会出现批注。</div>`;
      return;
    }
    const cards = state.clauses
      .map((c, idx) => {
        if (!c.audit) {
          if (c.status === "auditing") {
            return `<div class="comment-pass" data-anchor="${c.id}">
              <div class="progress-spinner" style="width:12px;height:12px;border-width:1.5px;"></div>
              <span style="color: var(--text-3);">第 ${idx + 1} 条审计中…</span>
            </div>`;
          }
          return "";
        }
        return commentCard(c, idx);
      })
      .filter(Boolean);

    list.innerHTML = cards.length
      ? cards.join("")
      : `<div class="comments-empty">完成一段审计后,这里会出现批注。</div>`;

    list.querySelectorAll("[data-anchor]").forEach(el => {
      el.addEventListener("click", e => {
        if (e.target.closest(".comment-adopt")) return;
        focusClause(el.dataset.anchor, /*scrollComment*/ false);
      });
    });
    list.querySelectorAll(".comment-adopt").forEach(b => {
      b.addEventListener("click", e => {
        e.stopPropagation();
        const id = b.dataset.id;
        const c = state.clauses.find(x => x.id === id);
        if (c) adoptClause(c);
      });
    });
  }

  function commentCard(c, idx) {
    const a = c.audit;
    const lk = levelKey(a.level);
    const isLow = lk === "low";
    if (isLow && !a.rule_hits?.length) {
      return `<div class="comment-pass" data-anchor="${c.id}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>第 ${idx + 1} 条 · 通过 (${esc(a.risk_type || "其他")})</span>
      </div>`;
    }
    return `<article class="comment" data-anchor="${c.id}">
      <div class="comment-head">
        <span class="chip ${lk}"><span class="chip-dot"></span>${esc(a.level || "中风险")}</span>
        <span class="chip">${esc(a.risk_type || "其他")}</span>
        ${a.need_review ? '<span class="chip review">需复核</span>' : ""}
        <span class="comment-anchor">#${idx + 1}</span>
      </div>
      <div class="comment-body">
        <strong>风险分析</strong>
        <p>${esc(a.reason || "").replace(/\n/g, "<br>")}</p>
        <strong>修改建议</strong>
        <p>${esc(a.suggestion || "").replace(/\n/g, "<br>")}</p>
      </div>
      <div class="comment-foot">
        <span class="mono">RPN ${a.rpn ?? "·"}</span>
        <span class="mono">置信 ${(a.confidence ?? 0).toFixed(2)}</span>
        <span class="grow"></span>
        <button class="comment-adopt" data-id="${c.id}">采纳</button>
      </div>
    </article>`;
  }

  function focusClause(id, scrollComment = true) {
    document.querySelectorAll(".clause").forEach(el => el.classList.toggle("active", el.dataset.id === id));
    document.querySelectorAll(".comments-inner [data-anchor]").forEach(el => el.classList.toggle("active", el.dataset.anchor === id));
    const target = document.querySelector(`.clause[data-id="${id}"]`);
    if (target) target.scrollIntoView({behavior: "smooth", block: "center"});
    if (scrollComment) {
      const c = document.querySelector(`.comments-inner [data-anchor="${id}"]`);
      if (c) c.scrollIntoView({behavior: "smooth", block: "nearest"});
    }
  }

  function renderTiming() {
    const t = state.timing || {};
    $("rv-timing").innerHTML = Object.entries(t).map(([k, v]) => `
      <div class="timing-cell">
        <div class="timing-v">${typeof v === "number" ? v.toFixed(3) + "s" : v}</div>
        <div class="timing-k">${esc(k)}</div>
      </div>
    `).join("");
  }

  // ====== Per-clause audit (concurrency = 2) ======
  async function startBatchAudit() {
    const total = state.clauses.length;
    if (!total) {
      $("rv-progress").classList.add("done");
      return;
    }
    let done = 0;
    let worst = state.initialAudit;
    state.aborter = new AbortController();
    const updateProgress = () => {
      $("rv-progress-text").innerHTML = `逐段审计 <b>${done} / ${total}</b>`;
      $("rv-progress-fill").style.width = `${(done / total) * 100}%`;
      const sub = $("rv-sub-progress");
      if (sub) sub.innerHTML = `逐段审计 <b>${done} / ${total}</b>`;
    };
    updateProgress();

    let cursor = 0;
    const concurrency = 2;
    const worker = async () => {
      while (cursor < total) {
        const i = cursor++;
        const c = state.clauses[i];
        c.status = "auditing";
        renderClauses();
        renderComments();
        try {
          const res = await fetch(`${API}/audit`, {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({clause: c.text}),
            signal: state.aborter.signal,
          });
          if (!res.ok) throw new Error("HTTP " + res.status);
          const data = await res.json();
          c.audit = data;
          c.status = "done";
          // 更新最严重
          if (riskRank(data.level) > riskRank(worst?.level)) {
            worst = data;
            paintBanner(data);
          }
        } catch (e) {
          if (e.name === "AbortError") return;
          c.status = "error";
          c.audit = {level: "中风险", risk_type: "其他", reason: "审计失败:" + e.message, suggestion: "请稍后重试。", rpn: 0, confidence: 0};
        }
        done++;
        updateProgress();
        renderClauses();
        renderComments();
      }
    };
    await Promise.all(Array.from({length: Math.min(concurrency, total)}, worker));
    $("rv-progress").classList.add("done");
    const sub = $("rv-sub-progress");
    if (sub) sub.innerHTML = `<span style="color: var(--low);">●</span> 审计完成 <b>${total} / ${total}</b>`;
  }
  function riskRank(level) {
    const s = String(level || "");
    if (s.includes("高")) return 3;
    if (s.includes("中")) return 2;
    if (s.includes("低")) return 1;
    return 0;
  }

  // ====== Export ======
  async function doExport(fmt) {
    // 用「最严重」那条作为导出主体
    const worst = pickWorst();
    if (!worst) { toast("请先完成审计", "error"); return; }
    try {
      const fd = new FormData();
      fd.append("format_type", fmt);
      fd.append("audit_payload", JSON.stringify(worst));
      const res = await fetch(`${API}/export`, {method: "POST", body: fd});
      if (!res.ok) throw new Error((await res.json().catch(() => ({}))).detail || res.statusText);
      const data = await res.json();
      const a = document.createElement("a");
      a.href = `${API}/files/${encodeURIComponent(data.filename)}`;
      a.download = data.filename;
      document.body.appendChild(a); a.click(); a.remove();
      toast(`${fmt.toUpperCase()} 已生成并下载`, "success");
    } catch (e) {
      toast("导出失败:" + e.message, "error");
    }
  }
  function pickWorst() {
    let worst = state.initialAudit;
    state.clauses.forEach(c => {
      if (c.audit && riskRank(c.audit.level) > riskRank(worst?.level)) worst = c.audit;
    });
    return worst;
  }
  document.addEventListener("click", e => {
    const t = e.target.closest("[data-export]");
    if (t) doExport(t.dataset.export);
  });

  // ====== Adopt ======
  async function adoptClause(c) {
    if (!c.audit) return;
    try {
      const res = await fetch(`${API}/history/add`, {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({
          clause: c.text,
          risk_type: c.audit.risk_type,
          risk_level: c.audit.risk_level,
          suggestion: c.audit.suggestion,
        }),
      });
      if (!res.ok) throw new Error((await res.json().catch(() => ({}))).detail || res.statusText);
      const data = await res.json();
      toast(`已采纳入库,共 ${data.total} 条`, "success");
    } catch (e) {
      toast("入库失败:" + e.message, "error");
    }
  }

  // ====== Drawer ======
  function openDrawer() { $("drawer").classList.add("show"); $("mask").classList.add("show"); }
  function closeDrawer() { $("drawer").classList.remove("show"); $("mask").classList.remove("show"); }
  async function openHistory() {
    openDrawer();
    $("drawer-count").textContent = "";
    $("drawer-body").innerHTML = `<div style="text-align:center;padding:48px;color:var(--text-3);font-size:13px;">加载中…</div>`;
    try {
      const res = await fetch(`${API}/history?limit=50`);
      const data = await res.json();
      const items = data.items || [];
      $("drawer-count").textContent = `共 ${data.total ?? items.length} 条`;
      $("drawer-body").innerHTML = items.length
        ? items.map(it => `
            <div class="hist-item">
              <div class="hi-meta">
                <span class="chip ${levelKey(it.risk_level)}">${esc(it.risk_level || "")}</span>
                <span class="chip">${esc(it.risk_type || "")}</span>
              </div>
              <div class="hi-c">${esc(it.clause || "")}</div>
              <div class="hi-s">${esc(it.suggestion || "")}</div>
            </div>
          `).join("")
        : `<div style="text-align:center;padding:60px 20px;color:var(--text-3);font-size:13px;">采纳库为空。在批注上点击「采纳」,这里会出现你的第一条记录。</div>`;
    } catch (e) {
      $("drawer-body").innerHTML = `<div style="color:var(--high);padding:24px;font-size:13px;">加载失败:${esc(e.message)}</div>`;
    }
  }

  // ====== Health ======
  async function openHealth() {
    $("health-modal").classList.add("show");
    $("health-mask").classList.add("show");
    $("health-list").innerHTML = `<div style="color: var(--text-3); text-align:center; padding: 16px;">检测中…</div>`;
    try {
      const res = await fetch(`${API}/health`);
      const d = await res.json();
      const row = (label, ok, extra = "") => `
        <div class="health-row">
          <span>${label}</span>
          <span class="h-status ${ok ? "h-ok" : "h-fail"}">
            <span class="h-dot"></span>${ok ? "正常" : "异常"}${extra ? `<span style="color: var(--text-3); margin-left: 6px; font-weight: 400;">${esc(extra)}</span>` : ""}
          </span>
        </div>`;
      $("health-list").innerHTML = `
        ${row("大语言模型 (GLM-4.7-Flash)", d.llm, d.llm_error || "")}
        ${row("向量知识库", d.vector_db, d.vector_db_error || "")}
        ${row("历史采纳库", d.historical_db, d.historical_db_error || "")}
        <div class="health-row">
          <span>已加载规则</span>
          <span class="h-status" style="color: var(--text);">${d.rules_loaded ?? 0} 条</span>
        </div>
        <div class="health-row">
          <span>历史条目</span>
          <span class="h-status" style="color: var(--text);">${d.historical_count ?? 0} 条</span>
        </div>
      `;
    } catch (e) {
      $("health-list").innerHTML = `<div class="health-row" style="color: var(--high);">连接失败:${esc(e.message)}</div>`;
    }
  }
  function closeHealth() { $("health-modal").classList.remove("show"); $("health-mask").classList.remove("show"); }

  // Wire navigation
  $("btn-history").onclick = openHistory;
  $("btn-health").onclick = openHealth;
  $("drawer-close").onclick = closeDrawer;
  $("mask").onclick = closeDrawer;
  $("health-close").onclick = closeHealth;
  $("health-mask").onclick = closeHealth;
  document.addEventListener("keydown", e => {
    if (e.key === "Escape") { closeDrawer(); closeHealth(); }
  });
</script>
</body>
</html>
